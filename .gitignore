android/app/src/main/assets/capacitor.plugins.json

# ==========================================
# Android Builds & Configurations
# ==========================================
# Ignore local gradle caches and Android Studio specific local properties
.gradle/
android/.gradle/
android/local.properties
android/captures/
android/app/build/
android/build/
android/.navigation/
android/app/.navigation/

# Android signing keys (Highly critical to keep private)
*.jks
*.keystore
*.pk8
*.pem

# ==========================================
# Packages & Test Releases
# ==========================================
# Ignore all builds/APKs except the official pre-compiled test package
*.apk
*.aab
!release/
!release/FitForge.apk

# ==========================================
# Environment Variables & Secret Credentials
# ==========================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
*.env.*

